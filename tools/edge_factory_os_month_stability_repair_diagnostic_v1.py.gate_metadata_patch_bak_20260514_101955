    attention: List[str] = []
    info: List[str] = []

    contract = load_json(REPAIR_CONTRACT_LATEST)
    runner = load_json(REGIME_FILTERED_RUNNER_LATEST)
    evaluator = load_json(REGIME_FILTERED_EVAL_LATEST)

    if not isinstance(contract, dict):
        critical.append("month_stability_repair_contract_latest_missing")
        contract = {}

    if not isinstance(runner, dict):
        critical.append("regime_filtered_candidate_runner_latest_missing")
        runner = {}

    if not isinstance(evaluator, dict):
        critical.append("regime_filtered_candidate_evaluator_latest_missing")
        evaluator = {}

    if contract.get("research_key") != "MONTH_STABILITY_REPAIR_DIAGNOSTIC_V1":
        critical.append(f"unexpected_contract_key:{contract.get('research_key')}")

    if evaluator.get("evaluator_status") != "REGIME_FILTERED_CANDIDATE_EVALUATOR_PROMISING_MONTH_STABILITY_BLOCKED":
        critical.append(f"unexpected_evaluator_status:{evaluator.get('evaluator_status')}")

    if evaluator.get("only_month_stability_failed") is not True:
        critical.append("only_month_stability_failed_not_true")

    paths = runner.get("outputs") or {}
    candidate_csv = paths.get("candidate_trades_csv")

    if not candidate_csv:
        critical.append("candidate_trades_csv_missing_from_runner_outputs")

    candidate_path = Path(str(candidate_csv)) if candidate_csv else None

    if candidate_path is None or not candidate_path.exists():
        critical.append(f"candidate_trades_csv_not_found:{candidate_csv}")

    if critical:
        diagnostic_status = "MONTH_STABILITY_REPAIR_DIAGNOSTIC_CRITICAL_BLOCKED"
        severity = "CRITICAL"
        allowed_scope = "READ_ONLY_REVIEW"
        next_action = "FIX_INPUTS_BEFORE_REPAIR_DIAGNOSTIC"
        reason = "; ".join(critical)

        result = {
            "module": MODULE,
            "created_at_utc": NOW.isoformat(),
            "diagnostic_status": diagnostic_status,
            "severity": severity,
            "allowed_scope": allowed_scope,
            "next_action": next_action,
            "reason": reason,
            "critical": critical,
            "attention": attention,
            "info": info,
            "safety": {
                "read_only": True,
                "offline_only": True,
                "mutate_runtime_allowed": False,
                "launcher_allowed": False,
                "patch_runtime_allowed": False,
                "active_paper_allowed": False,
                "live_allowed": False,
                "capital_change_allowed": False,
                "family_disable_allowed": False,
                "real_orders_allowed": False,
                "execution_performed": False,
            },
        }

        dump_json(RUN_DIR / "month_stability_repair_diagnostic_v1_state.json", result)
        dump_json(LATEST_JSON, result)

        print("=" * 100)
        print("EDGE FACTORY OS MONTH STABILITY REPAIR DIAGNOSTIC v1")
        print("=" * 100)
        print(f"diagnostic_status: {diagnostic_status}")
        print(f"severity: {severity}")
        print(f"reason: {reason}")
        print(f"latest_json: {LATEST_JSON}")
        print("=" * 100)
        return 2

    import pandas as pd
    import numpy as np

    df = pd.read_csv(candidate_path)

    if "time" in df.columns:
        df["time"] = pd.to_datetime(df["time"], errors="coerce", utc=True)

    if "month" not in df.columns and "time" in df.columns:
        df["month"] = df["time"].dt.to_period("M").astype(str)

    ret_candidates = [c for c in df.columns if c.startswith("net_ret_") and c.endswith("_bps")]
    if not ret_candidates:
        critical.append("net_return_column_missing")
        ret_col = None
    else:
        ret_col = ret_candidates[0]

    feature_candidates = [
        "mean_mkt_ret3_bps",
        "mean_mkt_ret6_bps",
        "mkt_ret3_bps",
        "mkt_ret6_bps",
        "coin_ret6_bps",
        "entry_vol_quote",
        "mean_entry_vol_quote",
        "median_entry_vol_quote",
        "std_coin_ret3_bps",
        "mean_entry_range_bps",
        "entry_range_bps",
        "coin_ret3_bps",
    ]

    available_features = [c for c in feature_candidates if c in df.columns]

    if not available_features:
        critical.append("no_available_repair_features")

    if critical:
        diagnostic_status = "MONTH_STABILITY_REPAIR_DIAGNOSTIC_CRITICAL_BLOCKED"
        severity = "CRITICAL"
        allowed_scope = "READ_ONLY_REVIEW"
        next_action = "FIX_FEATURE_INPUTS"
        reason = "; ".join(critical)
        result = {
            "module": MODULE,
            "created_at_utc": NOW.isoformat(),
            "diagnostic_status": diagnostic_status,
            "severity": severity,
            "allowed_scope": allowed_scope,
            "next_action": next_action,
            "reason": reason,
            "critical": critical,
            "attention": attention,
            "info": info,
            "safety": {
                "read_only": True,
                "offline_only": True,
                "mutate_runtime_allowed": False,
                "launcher_allowed": False,
                "patch_runtime_allowed": False,
                "active_paper_allowed": False,
                "live_allowed": False,
                "capital_change_allowed": False,
                "family_disable_allowed": False,
                "real_orders_allowed": False,
                "execution_performed": False,
            },
        }
    else:
        baseline_summary = summarize(df, ret_col)

        monthly = df.groupby("month")[ret_col].agg(["count", "sum", "mean", "median"]).reset_index()
        monthly = monthly.rename(columns={"count": "trade_count", "sum": "total_net_bps", "mean": "mean_net_bps", "median": "median_net_bps"})
        monthly_wr = df.assign(win=df[ret_col] > 0).groupby("month")["win"].mean().reset_index().rename(columns={"win": "win_rate"})
        monthly_sym = df.groupby("month")["symbol"].nunique().reset_index().rename(columns={"symbol": "symbol_count"})
        monthly = monthly.merge(monthly_wr, on="month", how="left").merge(monthly_sym, on="month", how="left")

        bad_months = monthly[monthly["total_net_bps"] < 0].sort_values("total_net_bps", ascending=True)
        good_months = monthly[monthly["total_net_bps"] > 0].sort_values("total_net_bps", ascending=False)

        filter_results = []

        for feature in available_features:
            s = df[feature].dropna()

            if len(s) < 50:
                continue

            qs = sorted(set([0.20, 0.25, 0.33, 0.50, 0.67, 0.75, 0.80]))
            thresholds = []
            for q in qs:
                try:
                    thresholds.append(float(s.quantile(q)))
                except Exception:
                    pass

            thresholds = sorted(set([round(x, 10) for x in thresholds]))

            for thr in thresholds:
                # keep high side
                try:
                    mask_hi = df[feature] >= thr
                    filter_results.append(evaluate_filter(df, ret_col, f"{feature} >= {thr}", mask_hi))
                except Exception:
                    pass

                # keep low side
                try:
                    mask_lo = df[feature] <= thr
                    filter_results.append(evaluate_filter(df, ret_col, f"{feature} <= {thr}", mask_lo))
                except Exception:
                    pass

        # Simple interaction repairs, still diagnostic only.
        if "mean_mkt_ret3_bps" in df.columns and "coin_ret6_bps" in df.columns:
            m1 = df["mean_mkt_ret3_bps"] >= df["mean_mkt_ret3_bps"].quantile(0.33)
            m2 = df["coin_ret6_bps"] >= df["coin_ret6_bps"].quantile(0.33)
            filter_results.append(evaluate_filter(df, ret_col, "mean_mkt_ret3_bps >= q33 AND coin_ret6_bps >= q33", m1 & m2))

        if "mean_mkt_ret6_bps" in df.columns and "entry_vol_quote" in df.columns:
            m1 = df["mean_mkt_ret6_bps"] >= df["mean_mkt_ret6_bps"].quantile(0.33)
            m2 = df["entry_vol_quote"] >= df["entry_vol_quote"].quantile(0.25)
            filter_results.append(evaluate_filter(df, ret_col, "mean_mkt_ret6_bps >= q33 AND entry_vol_quote >= q25", m1 & m2))

        if "coin_ret6_bps" in df.columns and "entry_range_bps" in df.columns:
            m1 = df["coin_ret6_bps"] >= df["coin_ret6_bps"].quantile(0.33)
            m2 = df["entry_range_bps"] <= df["entry_range_bps"].quantile(0.75)
            filter_results.append(evaluate_filter(df, ret_col, "coin_ret6_bps >= q33 AND entry_range_bps <= q75", m1 & m2))

        filter_results.sort(key=lambda x: x.get("diagnostic_score", 0), reverse=True)

        full_quality_preview = [r for r in filter_results if r.get("diagnostic_full_quality_pass_preview") is True]
        month_repaired = [
            r for r in filter_results
            if fnum(safe_get(r, ["kept_all", "positive_month_rate"]), 0) >= 0.55
            and inum(safe_get(r, ["kept_all", "trade_count"])) >= 300
        ]

        best_result = filter_results[0] if filter_results else None
        best_full_quality = full_quality_preview[0] if full_quality_preview else None
        best_month_repaired = month_repaired[0] if month_repaired else None

        diagnostic_table_path = RUN_DIR / "month_stability_repair_filter_results.json"
        monthly_table_path = RUN_DIR / "month_stability_repair_monthly_table.csv"

        dump_json(diagnostic_table_path, {"filter_results": filter_results[:300]})
        monthly.to_csv(monthly_table_path, index=False)

        findings = []

        findings.append({
            "finding_id": "MSR_F1_BASELINE_MONTH_STABILITY_BLOCKER_CONFIRMED",
            "severity": "HIGH",
            "claim": "The candidate remains blocked by all-period positive month rate.",
            "evidence": {
                "baseline_positive_month_rate": baseline_summary.get("positive_month_rate"),
                "baseline_trade_count": baseline_summary.get("trade_count"),
                "bad_months": bad_months.to_dict("records"),
                "good_months": good_months.to_dict("records"),
            },
        })

        if best_month_repaired:
            findings.append({
                "finding_id": "MSR_F2_MONTH_STABILITY_REPAIR_CANDIDATE_FOUND_DIAGNOSTIC_ONLY",
                "severity": "ATTENTION",
                "claim": "A pre-outcome filter improved all-period positive month rate to the release threshold region.",
                "evidence": {
                    "filter_name": best_month_repaired.get("filter_name"),
                    "kept_all": best_month_repaired.get("kept_all"),
                    "kept_oos": best_month_repaired.get("kept_oos"),
                    "failed_checks": best_month_repaired.get("failed_checks"),
                },
                "interpretation": "This does not approve release. It may justify a new repair candidate contract only if overfit guards are acceptable.",
            })
        else:
            findings.append({
                "finding_id": "MSR_F2_NO_MONTH_STABILITY_REPAIR_FOUND",
                "severity": "ATTENTION",
                "claim": "No tested pre-outcome repair filter achieved the minimum all-positive-month-rate with sufficient sample.",
                "evidence": {
                    "tested_filter_count": len(filter_results),
                    "best_filter": best_result,
                },
            })

        if best_full_quality:
            findings.append({
                "finding_id": "MSR_F3_FULL_QUALITY_PREVIEW_REPAIR_FOUND_DIAGNOSTIC_ONLY",
                "severity": "ATTENTION",
                "claim": "A tested repair filter passed all preview checks diagnostically.",
                "evidence": {
                    "filter_name": best_full_quality.get("filter_name"),
                    "kept_all": best_full_quality.get("kept_all"),
                    "kept_train": best_full_quality.get("kept_train"),
                    "kept_oos": best_full_quality.get("kept_oos"),
                },
                "interpretation": "Even if preview passes, a new contract/hash/full runner/evaluator/release gate are still required.",
            })

        diagnostic_status = "MONTH_STABILITY_REPAIR_DIAGNOSTIC_COMPLETE"
        severity = "ATTENTION"
        allowed_scope = "READ_ONLY_RESEARCH"
        next_action = "EVALUATE_MONTH_STABILITY_REPAIR_DIAGNOSTIC"
        reason = (
            f"tested_filter_count={len(filter_results)}; "
            f"month_repaired_count={len(month_repaired)}; "
            f"full_quality_preview_count={len(full_quality_preview)}"
        )

        result = {
            "module": MODULE,
            "created_at_utc": NOW.isoformat(),

            "diagnostic_status": diagnostic_status,
            "severity": severity,
            "allowed_scope": allowed_scope,
            "next_action": next_action,
            "reason": reason,

            "contract_source": str(REPAIR_CONTRACT_LATEST),
            "runner_source": str(REGIME_FILTERED_RUNNER_LATEST),
            "evaluator_source": str(REGIME_FILTERED_EVAL_LATEST),

            "source_candidate_route_hash": safe_get(contract, ["source_candidate", "candidate_route_hash"]),
            "candidate_trades_csv": str(candidate_path),
            "ret_col": ret_col,
            "available_features": available_features,

            "baseline_summary": baseline_summary,
            "monthly_table": monthly.to_dict("records"),
            "bad_months": bad_months.to_dict("records"),
            "good_months": good_months.to_dict("records"),

            "tested_filter_count": len(filter_results),
            "month_repaired_count": len(month_repaired),
            "full_quality_preview_count": len(full_quality_preview),

            "best_filter_by_score": best_result,
            "best_month_repaired_filter": best_month_repaired,
            "best_full_quality_preview_filter": best_full_quality,
            "top_filter_results": filter_results[:20],

            "outputs": {
                "filter_results_json": str(diagnostic_table_path),
                "monthly_table_csv": str(monthly_table_path),
            },

